generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum MembershipRole {
  OWNER
  ADMIN
  MEMBER
  VIEWER
}

enum MembershipStatus {
  ACTIVE
  INVITED
  SUSPENDED
}

enum DocumentStatus {
  PENDING
  PROCESSING
  INDEXED
  FAILED
  ARCHIVED
}

enum DocumentSourceType {
  UPLOAD
  URL
  NOTION
  GOOGLE_DRIVE
  CONFLUENCE
  SLACK
  GITHUB
  API
}

enum ConnectorProvider {
  GOOGLE_DRIVE
  NOTION
  CONFLUENCE
  SLACK
  GITHUB
}

enum ConnectorStatus {
  DISCONNECTED
  CONNECTED
  SYNCING
  ERROR
  PAUSED
}

enum ConnectorSyncStatus {
  QUEUED
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
}

enum WorkflowStatus {
  DRAFT
  ACTIVE
  PAUSED
  ARCHIVED
}

enum WorkflowTriggerType {
  MANUAL
  SCHEDULE
  CONNECTOR_WEBHOOK
  DOCUMENT_CREATED
}

enum WorkflowRunStatus {
  QUEUED
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
}

enum ConversationStatus {
  ACTIVE
  ARCHIVED
}

enum MessageRole {
  SYSTEM
  USER
  ASSISTANT
  TOOL
}

enum PromptStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum MemoryType {
  SHORT_TERM
  LONG_TERM
  SUMMARY
  PREFERENCE
  FACT
  TASK
}

enum MemoryStatus {
  ACTIVE
  ARCHIVED
}

enum BillingPlan {
  FREE
  PRO
  ENTERPRISE
}

enum SubscriptionStatus {
  INCOMPLETE
  INCOMPLETE_EXPIRED
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
  UNPAID
  PAUSED
}

enum BillingUsageMetric {
  AI_TOKENS
  STORAGE_GB
  SEATS
}

enum EvaluationRunStatus {
  QUEUED
  RUNNING
  COMPLETED
  FAILED
}

enum VoiceProvider {
  OPENAI_REALTIME
  ELEVENLABS
  DEEPGRAM
}

enum VoiceSessionStatus {
  INITIALIZING
  CONNECTING
  LISTENING
  SPEAKING
  INTERRUPTED
  ENDED
  FAILED
}

enum TranscriptionProvider {
  DEEPGRAM
  WHISPER
  ASSEMBLYAI
}

enum AudioSessionStatus {
  CREATED
  STREAMING
  PROCESSING
  COMPLETED
  FAILED
  CANCELLED
}

enum TranscriptStatus {
  DRAFT
  STREAMING
  PROCESSING
  COMPLETED
  FAILED
  ARCHIVED
}

model User {
  id          String       @id @default(cuid())
  clerkId     String       @unique @map("clerk_id")
  email       String       @unique
  firstName   String?      @map("first_name")
  lastName    String?      @map("last_name")
  imageUrl    String?      @map("image_url")
  memberships Membership[]
  documents   Document[]   @relation("DocumentCreatedBy")
  messages    Message[]
  prompts     Prompt[]     @relation("PromptCreatedBy")
  observabilityEvents ObservabilityEvent[]
  auditLogs   AuditLog[]
  connectors  Connector[]  @relation("ConnectorCreatedBy")
  workflows   Workflow[]   @relation("WorkflowCreatedBy")
  apiKeys     ApiKey[]      @relation("ApiKeyCreatedBy")
  voiceSessions VoiceSession[]
  audioSessions AudioSession[]
  transcripts Transcript[]
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")

  @@index([email])
  @@map("users")
}

model Organization {
  id          String       @id @default(cuid())
  clerkId     String       @unique @map("clerk_id")
  name        String
  slug        String?
  imageUrl    String?      @map("image_url")
  dataRegion  String       @default("us") @map("data_region")
  retentionDays Int        @default(365) @map("retention_days")
  memberships Membership[]
  documents   Document[]
  documentChunks DocumentChunk[]
  embeddings  Embedding[]
  conversations Conversation[]
  messages    Message[]
  conversationSummaries ConversationSummary[]
  memoryItems MemoryItem[]
  prompts     Prompt[]
  retrievalLogs RetrievalLog[]
  observabilityEvents ObservabilityEvent[]
  auditLogs AuditLog[]
  rateLimitBuckets RateLimitBucket[]
  connectors Connector[]
  connectorSyncJobs ConnectorSyncJob[]
  workflows Workflow[]
  workflowRuns WorkflowRun[]
  billingCustomer BillingCustomer?
  subscriptions Subscription[]
  usageEvents UsageEvent[]
  invoices Invoice[]
  evaluationDatasets EvaluationDataset[]
  evaluationCases EvaluationCase[]
  evaluationRuns EvaluationRun[]
  evaluationResults EvaluationResult[]
  apiKeys ApiKey[]
  apiRequestLogs ApiRequestLog[]
  voiceSessions VoiceSession[]
  audioSessions AudioSession[]
  transcripts Transcript[]
  transcriptSegments TranscriptSegment[]
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")

  @@index([slug])
  @@map("organizations")
}

model Membership {
  id                String           @id @default(cuid())
  userId            String?          @map("user_id")
  organizationId    String           @map("organization_id")
  clerkInvitationId String?          @unique @map("clerk_invitation_id")
  clerkRole         String           @map("clerk_role")
  role              MembershipRole   @default(MEMBER)
  status            MembershipStatus @default(ACTIVE)
  invitedEmail      String?          @map("invited_email")
  user              User?            @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization      Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt         DateTime         @default(now()) @map("created_at")
  updatedAt         DateTime         @updatedAt @map("updated_at")

  @@unique([userId, organizationId])
  @@index([organizationId, role])
  @@index([invitedEmail])
  @@map("memberships")
}

model Document {
  id             String             @id @default(cuid())
  organizationId String             @map("organization_id")
  createdById    String?            @map("created_by_id")
  title          String
  sourceType     DocumentSourceType @default(UPLOAD) @map("source_type")
  sourceUri      String?            @map("source_uri")
  mimeType       String?            @map("mime_type")
  checksum       String?
  metadata       Json               @default("{}")
  status         DocumentStatus     @default(PENDING)
  tokenCount     Int                @default(0) @map("token_count")
  chunkCount     Int                @default(0) @map("chunk_count")
  errorMessage   String?            @map("error_message")
  organization   Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy      User?              @relation("DocumentCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  chunks         DocumentChunk[]
  retrievalLogs  RetrievalLog[]
  deletedAt      DateTime?          @map("deleted_at")
  createdAt      DateTime           @default(now()) @map("created_at")
  updatedAt      DateTime           @updatedAt @map("updated_at")

  @@index([organizationId, status, deletedAt])
  @@index([organizationId, sourceType])
  @@index([organizationId, checksum])
  @@map("documents")
}

model Connector {
  id                 String            @id @default(cuid())
  organizationId     String            @map("organization_id")
  createdById        String?           @map("created_by_id")
  provider           ConnectorProvider
  name               String
  status             ConnectorStatus   @default(DISCONNECTED)
  config             Json              @default("{}")
  credentials        Json              @default("{}")
  syncCursor         String?           @map("sync_cursor")
  lastSyncStartedAt  DateTime?         @map("last_sync_started_at")
  lastSyncFinishedAt DateTime?         @map("last_sync_finished_at")
  lastWebhookAt      DateTime?         @map("last_webhook_at")
  errorMessage       String?           @map("error_message")
  isEnabled          Boolean           @default(true) @map("is_enabled")
  syncIntervalMin    Int               @default(60) @map("sync_interval_min")
  organization       Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy          User?             @relation("ConnectorCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  syncJobs           ConnectorSyncJob[]
  deletedAt          DateTime?         @map("deleted_at")
  createdAt          DateTime          @default(now()) @map("created_at")
  updatedAt          DateTime          @updatedAt @map("updated_at")

  @@unique([organizationId, provider, name])
  @@index([organizationId, provider, status, deletedAt])
  @@index([organizationId, isEnabled, syncIntervalMin])
  @@map("connectors")
}

model ConnectorSyncJob {
  id             String              @id @default(cuid())
  organizationId String              @map("organization_id")
  connectorId    String              @map("connector_id")
  status         ConnectorSyncStatus @default(QUEUED)
  syncType       String              @default("manual") @map("sync_type")
  startedAt      DateTime?           @map("started_at")
  finishedAt     DateTime?           @map("finished_at")
  cursorBefore   String?             @map("cursor_before")
  cursorAfter    String?             @map("cursor_after")
  documentsSeen  Int                 @default(0) @map("documents_seen")
  documentsAdded Int                 @default(0) @map("documents_added")
  documentsUpdated Int               @default(0) @map("documents_updated")
  errorMessage   String?             @map("error_message")
  metadata       Json                @default("{}")
  organization   Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  connector      Connector           @relation(fields: [connectorId], references: [id], onDelete: Cascade)
  createdAt      DateTime            @default(now()) @map("created_at")
  updatedAt      DateTime            @updatedAt @map("updated_at")

  @@index([organizationId, connectorId, status])
  @@index([organizationId, status, createdAt])
  @@map("connector_sync_jobs")
}

model Workflow {
  id                 String              @id @default(cuid())
  organizationId     String              @map("organization_id")
  createdById        String?             @map("created_by_id")
  name               String
  description        String?
  status             WorkflowStatus      @default(DRAFT)
  triggerType        WorkflowTriggerType @map("trigger_type")
  triggerConfig      Json                @default("{}") @map("trigger_config")
  actions            Json                @default("[]")
  lastRunAt          DateTime?           @map("last_run_at")
  nextRunAt          DateTime?           @map("next_run_at")
  lastRunStatus      WorkflowRunStatus?  @map("last_run_status")
  organization       Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy          User?               @relation("WorkflowCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  runs               WorkflowRun[]
  deletedAt          DateTime?           @map("deleted_at")
  createdAt          DateTime            @default(now()) @map("created_at")
  updatedAt          DateTime            @updatedAt @map("updated_at")

  @@index([organizationId, status, triggerType, deletedAt])
  @@index([organizationId, nextRunAt])
  @@map("workflows")
}

model WorkflowRun {
  id             String            @id @default(cuid())
  organizationId String            @map("organization_id")
  workflowId     String            @map("workflow_id")
  status         WorkflowRunStatus @default(QUEUED)
  triggerType    WorkflowTriggerType @map("trigger_type")
  input          Json              @default("{}")
  output         Json              @default("{}")
  errorMessage   String?           @map("error_message")
  startedAt      DateTime?         @map("started_at")
  finishedAt     DateTime?         @map("finished_at")
  organization   Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  workflow       Workflow          @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  steps          WorkflowRunStep[]
  createdAt      DateTime          @default(now()) @map("created_at")
  updatedAt      DateTime          @updatedAt @map("updated_at")

  @@index([organizationId, workflowId, status])
  @@index([organizationId, status, createdAt])
  @@map("workflow_runs")
}

model WorkflowRunStep {
  id             String            @id @default(cuid())
  workflowRunId  String            @map("workflow_run_id")
  actionType     String            @map("action_type")
  status         WorkflowRunStatus @default(QUEUED)
  input          Json              @default("{}")
  output         Json              @default("{}")
  errorMessage   String?           @map("error_message")
  startedAt      DateTime?         @map("started_at")
  finishedAt     DateTime?         @map("finished_at")
  run            WorkflowRun       @relation(fields: [workflowRunId], references: [id], onDelete: Cascade)
  createdAt      DateTime          @default(now()) @map("created_at")
  updatedAt      DateTime          @updatedAt @map("updated_at")

  @@index([workflowRunId, status])
  @@map("workflow_run_steps")
}

model DocumentChunk {
  id             String       @id @default(cuid())
  organizationId String       @map("organization_id")
  documentId     String       @map("document_id")
  content        String
  contentHash    String       @map("content_hash")
  chunkIndex     Int          @map("chunk_index")
  tokenCount     Int          @default(0) @map("token_count")
  startChar      Int?         @map("start_char")
  endChar        Int?         @map("end_char")
  metadata       Json         @default("{}")
  document       Document     @relation(fields: [documentId], references: [id], onDelete: Cascade)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  embeddings     Embedding[]
  retrievalLogs  RetrievalLog[]
  deletedAt      DateTime?    @map("deleted_at")
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  @@unique([documentId, chunkIndex])
  @@index([organizationId, documentId, deletedAt])
  @@index([organizationId, contentHash])
  @@map("document_chunks")
}

model Embedding {
  id             String                   @id @default(cuid())
  organizationId String                   @map("organization_id")
  chunkId        String                   @map("chunk_id")
  provider       String
  model          String
  dimensions     Int
  vector         Unsupported("vector(1536)")
  metadata       Json                     @default("{}")
  chunk          DocumentChunk            @relation(fields: [chunkId], references: [id], onDelete: Cascade)
  organization   Organization             @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  retrievalLogs  RetrievalLog[]
  deletedAt      DateTime?                @map("deleted_at")
  createdAt      DateTime                 @default(now()) @map("created_at")
  updatedAt      DateTime                 @updatedAt @map("updated_at")

  @@unique([chunkId, provider, model])
  @@index([organizationId, provider, model, deletedAt])
  @@map("embeddings")
}

model Conversation {
  id             String             @id @default(cuid())
  organizationId String             @map("organization_id")
  title          String
  status         ConversationStatus @default(ACTIVE)
  metadata       Json               @default("{}")
  organization   Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  messages       Message[]
  summaries      ConversationSummary[]
  memoryItems    MemoryItem[]
  retrievalLogs  RetrievalLog[]
  voiceSessions  VoiceSession[]
  deletedAt      DateTime?          @map("deleted_at")
  createdAt      DateTime           @default(now()) @map("created_at")
  updatedAt      DateTime           @updatedAt @map("updated_at")

  @@index([organizationId, status, deletedAt])
  @@map("conversations")
}

model Message {
  id             String       @id @default(cuid())
  organizationId String       @map("organization_id")
  conversationId String       @map("conversation_id")
  userId         String?      @map("user_id")
  role           MessageRole
  content        String
  metadata       Json         @default("{}")
  tokenCount     Int          @default(0) @map("token_count")
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User?        @relation(fields: [userId], references: [id], onDelete: SetNull)
  memoryItems    MemoryItem[]
  deletedAt      DateTime?    @map("deleted_at")
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  @@index([organizationId, conversationId, createdAt])
  @@index([organizationId, role])
  @@map("messages")
}

model ConversationSummary {
  id                  String       @id @default(cuid())
  organizationId      String       @map("organization_id")
  conversationId      String       @map("conversation_id")
  summary             String
  messageCount        Int          @default(0) @map("message_count")
  coveredMessageIds   String[]     @default([]) @map("covered_message_ids")
  inputTokenCount     Int          @default(0) @map("input_token_count")
  summaryTokenCount   Int          @default(0) @map("summary_token_count")
  compressionRatio    Float?       @map("compression_ratio")
  metadata            Json         @default("{}")
  organization        Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  conversation        Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  deletedAt           DateTime?    @map("deleted_at")
  createdAt           DateTime     @default(now()) @map("created_at")
  updatedAt           DateTime     @updatedAt @map("updated_at")

  @@index([organizationId, conversationId, createdAt])
  @@map("conversation_summaries")
}

model VoiceSession {
  id                String             @id @default(cuid())
  organizationId    String             @map("organization_id")
  userId            String?            @map("user_id")
  conversationId    String?            @map("conversation_id")
  provider          VoiceProvider      @default(OPENAI_REALTIME)
  model             String
  voice             String?
  status            VoiceSessionStatus @default(INITIALIZING)
  transport         String             @default("webrtc")
  inputAudioFormat  String             @default("pcm16") @map("input_audio_format")
  outputAudioFormat String             @default("pcm16") @map("output_audio_format")
  sampleRate        Int                @default(24000) @map("sample_rate")
  transcript        Json               @default("[]")
  metrics           Json               @default("{}")
  metadata          Json               @default("{}")
  startedAt         DateTime?          @map("started_at")
  endedAt           DateTime?          @map("ended_at")
  lastEventAt       DateTime?          @map("last_event_at")
  errorMessage      String?            @map("error_message")
  organization      Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user              User?              @relation(fields: [userId], references: [id], onDelete: SetNull)
  conversation      Conversation?      @relation(fields: [conversationId], references: [id], onDelete: SetNull)
  audioSessions     AudioSession[]
  deletedAt         DateTime?          @map("deleted_at")
  createdAt         DateTime           @default(now()) @map("created_at")
  updatedAt         DateTime           @updatedAt @map("updated_at")

  @@index([organizationId, status, deletedAt])
  @@index([organizationId, provider, createdAt])
  @@index([organizationId, conversationId])
  @@index([userId, createdAt])
  @@map("voice_sessions")
}

model AudioSession {
  id             String             @id @default(cuid())
  organizationId String             @map("organization_id")
  userId         String?            @map("user_id")
  voiceSessionId String?            @map("voice_session_id")
  provider       TranscriptionProvider
  status         AudioSessionStatus @default(CREATED)
  language       String             @default("en")
  sampleRate     Int                @default(16000) @map("sample_rate")
  channels       Int                @default(1)
  encoding       String             @default("linear16")
  source         String             @default("microphone")
  metadata       Json               @default("{}")
  startedAt      DateTime?          @map("started_at")
  endedAt        DateTime?          @map("ended_at")
  lastEventAt    DateTime?          @map("last_event_at")
  errorMessage   String?            @map("error_message")
  organization   Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User?              @relation(fields: [userId], references: [id], onDelete: SetNull)
  voiceSession   VoiceSession?      @relation(fields: [voiceSessionId], references: [id], onDelete: SetNull)
  transcripts    Transcript[]
  deletedAt      DateTime?          @map("deleted_at")
  createdAt      DateTime           @default(now()) @map("created_at")
  updatedAt      DateTime           @updatedAt @map("updated_at")

  @@index([organizationId, status, deletedAt])
  @@index([organizationId, provider, createdAt])
  @@index([voiceSessionId])
  @@index([userId, createdAt])
  @@map("audio_sessions")
}

model Transcript {
  id             String            @id @default(cuid())
  organizationId String            @map("organization_id")
  audioSessionId String            @map("audio_session_id")
  createdById    String?           @map("created_by_id")
  title          String
  status         TranscriptStatus  @default(DRAFT)
  language       String            @default("en")
  detectedLanguages String[]       @default([]) @map("detected_languages")
  speakerCount   Int               @default(0) @map("speaker_count")
  durationMs     Int               @default(0) @map("duration_ms")
  wordCount      Int               @default(0) @map("word_count")
  confidence     Float?
  fullText       String            @default("") @map("full_text")
  correctedText  String?           @map("corrected_text")
  metadata       Json              @default("{}")
  organization   Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  audioSession   AudioSession      @relation(fields: [audioSessionId], references: [id], onDelete: Cascade)
  createdBy      User?             @relation(fields: [createdById], references: [id], onDelete: SetNull)
  segments       TranscriptSegment[]
  deletedAt      DateTime?         @map("deleted_at")
  createdAt      DateTime          @default(now()) @map("created_at")
  updatedAt      DateTime          @updatedAt @map("updated_at")

  @@index([organizationId, status, deletedAt])
  @@index([organizationId, language, createdAt])
  @@index([audioSessionId])
  @@map("transcripts")
}

model TranscriptSegment {
  id             String       @id @default(cuid())
  organizationId String       @map("organization_id")
  transcriptId   String       @map("transcript_id")
  segmentIndex   Int          @map("segment_index")
  speakerLabel   String?      @map("speaker_label")
  language       String       @default("en")
  text           String
  correctedText  String?      @map("corrected_text")
  startMs        Int          @default(0) @map("start_ms")
  endMs          Int          @default(0) @map("end_ms")
  confidence     Float?
  words          Json         @default("[]")
  metadata       Json         @default("{}")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  transcript     Transcript   @relation(fields: [transcriptId], references: [id], onDelete: Cascade)
  deletedAt      DateTime?    @map("deleted_at")
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  @@unique([transcriptId, segmentIndex])
  @@index([organizationId, transcriptId, startMs])
  @@index([organizationId, speakerLabel])
  @@map("transcript_segments")
}

model MemoryItem {
  id              String         @id @default(cuid())
  organizationId  String         @map("organization_id")
  conversationId  String?        @map("conversation_id")
  sourceMessageId String?        @map("source_message_id")
  type            MemoryType     @default(LONG_TERM)
  status          MemoryStatus   @default(ACTIVE)
  content         String
  summary         String?
  importance      Float          @default(0.5)
  tokenCount      Int            @default(0) @map("token_count")
  provider        String?
  model           String?
  dimensions      Int?
  vector          Unsupported("vector(1536)")?
  metadata        Json           @default("{}")
  accessCount     Int            @default(0) @map("access_count")
  lastAccessedAt  DateTime?      @map("last_accessed_at")
  organization    Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  conversation    Conversation?  @relation(fields: [conversationId], references: [id], onDelete: SetNull)
  sourceMessage   Message?       @relation(fields: [sourceMessageId], references: [id], onDelete: SetNull)
  deletedAt       DateTime?      @map("deleted_at")
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")

  @@index([organizationId, type, status, deletedAt])
  @@index([organizationId, conversationId, createdAt])
  @@index([organizationId, importance])
  @@map("memory_items")
}

model Prompt {
  id             String       @id @default(cuid())
  organizationId String       @map("organization_id")
  createdById    String?      @map("created_by_id")
  name           String
  key            String
  version        Int          @default(1)
  status         PromptStatus @default(DRAFT)
  template       String
  metadata       Json         @default("{}")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy      User?        @relation("PromptCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  deletedAt      DateTime?    @map("deleted_at")
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  @@unique([organizationId, key, version])
  @@index([organizationId, status, deletedAt])
  @@map("prompts")
}

model RetrievalLog {
  id             String         @id @default(cuid())
  organizationId String         @map("organization_id")
  conversationId String?        @map("conversation_id")
  documentId     String?        @map("document_id")
  chunkId        String?        @map("chunk_id")
  embeddingId    String?        @map("embedding_id")
  query          String
  provider       String?
  model          String?
  similarity     Float?
  rank           Int?
  latencyMs      Int?           @map("latency_ms")
  metadata       Json           @default("{}")
  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  conversation   Conversation?  @relation(fields: [conversationId], references: [id], onDelete: SetNull)
  document       Document?      @relation(fields: [documentId], references: [id], onDelete: SetNull)
  chunk          DocumentChunk? @relation(fields: [chunkId], references: [id], onDelete: SetNull)
  embedding      Embedding?     @relation(fields: [embeddingId], references: [id], onDelete: SetNull)
  deletedAt      DateTime?      @map("deleted_at")
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")

  @@index([organizationId, conversationId, createdAt])
  @@index([organizationId, documentId])
  @@index([organizationId, chunkId])
  @@map("retrieval_logs")
}

model ObservabilityEvent {
  id             String        @id @default(cuid())
  organizationId String?       @map("organization_id")
  userId         String?       @map("user_id")
  category       String
  name           String
  level          String        @default("info")
  traceId        String?       @map("trace_id")
  provider       String?
  model          String?
  inputTokens    Int           @default(0) @map("input_tokens")
  outputTokens   Int           @default(0) @map("output_tokens")
  totalTokens    Int           @default(0) @map("total_tokens")
  estimatedCost  Float         @default(0) @map("estimated_cost")
  latencyMs      Int?          @map("latency_ms")
  metadata       Json          @default("{}")
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  user           User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  createdAt      DateTime      @default(now()) @map("created_at")

  @@index([organizationId, category, createdAt])
  @@index([organizationId, name, createdAt])
  @@index([traceId])
  @@map("observability_events")
}

model AuditLog {
  id             String        @id @default(cuid())
  organizationId String?       @map("organization_id")
  userId         String?       @map("user_id")
  action         String
  resource       String
  resourceId     String?       @map("resource_id")
  outcome        String        @default("success")
  ipAddress      String?       @map("ip_address")
  userAgent      String?       @map("user_agent")
  metadata       Json          @default("{}")
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  user           User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  createdAt      DateTime      @default(now()) @map("created_at")

  @@index([organizationId, action, createdAt])
  @@index([organizationId, resource, resourceId])
  @@index([userId, createdAt])
  @@map("audit_logs")
}

model RateLimitBucket {
  id             String        @id @default(cuid())
  organizationId String?       @map("organization_id")
  key            String
  route          String
  count          Int           @default(0)
  windowStart    DateTime      @map("window_start")
  expiresAt      DateTime      @map("expires_at")
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")

  @@unique([key, route, windowStart])
  @@index([organizationId, route, expiresAt])
  @@map("rate_limit_buckets")
}

model ApiKey {
  id                 String          @id @default(cuid())
  organizationId     String          @map("organization_id")
  createdById        String?         @map("created_by_id")
  name               String
  prefix             String
  keyHash            String          @unique @map("key_hash")
  scopes             Json            @default("[]")
  rateLimitPerMinute Int             @default(60) @map("rate_limit_per_minute")
  lastUsedAt         DateTime?       @map("last_used_at")
  expiresAt          DateTime?       @map("expires_at")
  revokedAt          DateTime?       @map("revoked_at")
  metadata           Json            @default("{}")
  organization       Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy          User?           @relation("ApiKeyCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  requestLogs        ApiRequestLog[]
  createdAt          DateTime        @default(now()) @map("created_at")
  updatedAt          DateTime        @updatedAt @map("updated_at")

  @@index([organizationId, revokedAt])
  @@index([organizationId, prefix])
  @@map("api_keys")
}

model ApiRequestLog {
  id             String       @id @default(cuid())
  organizationId String       @map("organization_id")
  apiKeyId       String?      @map("api_key_id")
  method         String
  path           String
  status         Int
  latencyMs      Int          @map("latency_ms")
  ipAddress      String?      @map("ip_address")
  userAgent      String?      @map("user_agent")
  metadata       Json         @default("{}")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  apiKey         ApiKey?      @relation(fields: [apiKeyId], references: [id], onDelete: SetNull)
  createdAt      DateTime     @default(now()) @map("created_at")

  @@index([organizationId, createdAt])
  @@index([apiKeyId, createdAt])
  @@index([organizationId, path, createdAt])
  @@map("api_request_logs")
}

model BillingCustomer {
  id               String       @id @default(cuid())
  organizationId   String       @unique @map("organization_id")
  stripeCustomerId String       @unique @map("stripe_customer_id")
  email            String?
  name             String?
  metadata         Json         @default("{}")
  organization     Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt        DateTime     @default(now()) @map("created_at")
  updatedAt        DateTime     @updatedAt @map("updated_at")

  @@index([organizationId])
  @@map("billing_customers")
}

model Subscription {
  id                     String             @id @default(cuid())
  organizationId         String             @map("organization_id")
  stripeSubscriptionId   String             @unique @map("stripe_subscription_id")
  stripeCustomerId       String             @map("stripe_customer_id")
  stripePriceId          String?            @map("stripe_price_id")
  stripeProductId        String?            @map("stripe_product_id")
  plan                   BillingPlan        @default(FREE)
  status                 SubscriptionStatus @default(INCOMPLETE)
  quantity               Int                @default(1)
  currentPeriodStart     DateTime?          @map("current_period_start")
  currentPeriodEnd       DateTime?          @map("current_period_end")
  cancelAtPeriodEnd      Boolean            @default(false) @map("cancel_at_period_end")
  canceledAt             DateTime?          @map("canceled_at")
  trialEndsAt            DateTime?          @map("trial_ends_at")
  metadata               Json               @default("{}")
  organization           Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  usageEvents            UsageEvent[]
  createdAt              DateTime           @default(now()) @map("created_at")
  updatedAt              DateTime           @updatedAt @map("updated_at")

  @@index([organizationId, status])
  @@index([stripeCustomerId])
  @@map("subscriptions")
}

model UsageEvent {
  id                  String             @id @default(cuid())
  organizationId      String             @map("organization_id")
  subscriptionId      String?            @map("subscription_id")
  metric              BillingUsageMetric
  quantity            Int
  unitAmount          Float              @default(0) @map("unit_amount")
  amount              Float              @default(0)
  stripeMeterEventId  String?            @unique @map("stripe_meter_event_id")
  stripeCustomerId    String?            @map("stripe_customer_id")
  idempotencyKey      String             @unique @map("idempotency_key")
  source              String             @default("internal")
  metadata            Json               @default("{}")
  occurredAt          DateTime           @default(now()) @map("occurred_at")
  organization        Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  subscription        Subscription?      @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)
  createdAt           DateTime           @default(now()) @map("created_at")

  @@index([organizationId, metric, occurredAt])
  @@index([subscriptionId, occurredAt])
  @@map("usage_events")
}

model Invoice {
  id              String       @id @default(cuid())
  organizationId  String       @map("organization_id")
  stripeInvoiceId String       @unique @map("stripe_invoice_id")
  stripeCustomerId String      @map("stripe_customer_id")
  status          String
  currency        String       @default("usd")
  subtotal        Int          @default(0)
  total           Int          @default(0)
  amountPaid      Int          @default(0) @map("amount_paid")
  hostedInvoiceUrl String?     @map("hosted_invoice_url")
  invoicePdf      String?      @map("invoice_pdf")
  periodStart     DateTime?    @map("period_start")
  periodEnd       DateTime?    @map("period_end")
  metadata        Json         @default("{}")
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")

  @@index([organizationId, createdAt])
  @@index([stripeCustomerId])
  @@map("invoices")
}

model EvaluationDataset {
  id             String           @id @default(cuid())
  organizationId String           @map("organization_id")
  name           String
  description    String?
  metadata       Json             @default("{}")
  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  cases          EvaluationCase[]
  runs           EvaluationRun[]
  deletedAt      DateTime?        @map("deleted_at")
  createdAt      DateTime         @default(now()) @map("created_at")
  updatedAt      DateTime         @updatedAt @map("updated_at")

  @@unique([organizationId, name])
  @@index([organizationId, deletedAt])
  @@map("evaluation_datasets")
}

model EvaluationCase {
  id                  String              @id @default(cuid())
  organizationId      String              @map("organization_id")
  datasetId           String              @map("dataset_id")
  query               String
  expectedAnswer      String?             @map("expected_answer")
  expectedCitationIds Json                @default("[]") @map("expected_citation_ids")
  requiredKeywords    Json                @default("[]") @map("required_keywords")
  expectedDocuments   Json                @default("[]") @map("expected_documents")
  metadata            Json                @default("{}")
  organization        Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  dataset             EvaluationDataset   @relation(fields: [datasetId], references: [id], onDelete: Cascade)
  results             EvaluationResult[]
  deletedAt           DateTime?           @map("deleted_at")
  createdAt           DateTime            @default(now()) @map("created_at")
  updatedAt           DateTime            @updatedAt @map("updated_at")

  @@index([organizationId, datasetId, deletedAt])
  @@map("evaluation_cases")
}

model EvaluationRun {
  id                 String              @id @default(cuid())
  organizationId     String              @map("organization_id")
  datasetId          String              @map("dataset_id")
  name               String
  status             EvaluationRunStatus @default(QUEUED)
  retrievalMode      String              @default("hybrid") @map("retrieval_mode")
  aggregateScores    Json                @default("{}") @map("aggregate_scores")
  metadata           Json                @default("{}")
  startedAt          DateTime?           @map("started_at")
  completedAt        DateTime?           @map("completed_at")
  organization       Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  dataset            EvaluationDataset   @relation(fields: [datasetId], references: [id], onDelete: Cascade)
  results            EvaluationResult[]
  createdAt          DateTime            @default(now()) @map("created_at")
  updatedAt          DateTime            @updatedAt @map("updated_at")

  @@index([organizationId, datasetId, createdAt])
  @@index([organizationId, status])
  @@map("evaluation_runs")
}

model EvaluationResult {
  id                    String         @id @default(cuid())
  organizationId        String         @map("organization_id")
  runId                 String         @map("run_id")
  caseId                String         @map("case_id")
  query                 String
  answer                String
  retrievedCitationIds  Json           @default("[]") @map("retrieved_citation_ids")
  retrievedDocumentIds  Json           @default("[]") @map("retrieved_document_ids")
  context               String?
  retrievalScore        Float          @default(0) @map("retrieval_score")
  hallucinationScore    Float          @default(0) @map("hallucination_score")
  responseQualityScore  Float          @default(0) @map("response_quality_score")
  overallScore          Float          @default(0) @map("overall_score")
  risk                  String         @default("medium")
  issues                Json           @default("[]")
  metadata              Json           @default("{}")
  organization          Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  run                   EvaluationRun  @relation(fields: [runId], references: [id], onDelete: Cascade)
  evaluationCase        EvaluationCase @relation(fields: [caseId], references: [id], onDelete: Cascade)
  createdAt             DateTime       @default(now()) @map("created_at")

  @@unique([runId, caseId])
  @@index([organizationId, runId])
  @@index([organizationId, overallScore])
  @@map("evaluation_results")
}
